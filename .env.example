# API server
PORT=8787
REFRESH_INTERVAL_MS=60000

# Optional: protect POST /api/ingest with Bearer token
INGEST_TOKEN=

# Optional per-account pull source URLs
# Server polls each URL and expects one of the following JSON shapes:
# 1) [{"id":"q1","modelName":"Gemini 3.1 Pro","remainingPercentage":55.1,"refreshTime":"12 hours, 20 min"}]
# 2) {"quotas":[{"modelName":"Claude Sonnet","remainingPercentage":22.8,"resetAt":"2026-03-10T00:00:00Z"}]}
ACCOUNT_1_QUOTA_SOURCE_URL=
ACCOUNT_2_QUOTA_SOURCE_URL=
ACCOUNT_3_QUOTA_SOURCE_URL=
ACCOUNT_4_QUOTA_SOURCE_URL=
ACCOUNT_5_QUOTA_SOURCE_URL=
ACCOUNT_6_QUOTA_SOURCE_URL=
ACCOUNT_7_QUOTA_SOURCE_URL=
ACCOUNT_8_QUOTA_SOURCE_URL=

# Optional external collector runner settings
INGEST_BASE_URL=http://127.0.0.1:8787
COLLECT_INTERVAL_MS=60000

# Optional per-account collector command (stdout must be valid JSON)
# Example:
# ACCOUNT_2_COLLECTOR_CMD=node scripts/sample-account-collector.js 2
ACCOUNT_1_COLLECTOR_CMD=
ACCOUNT_2_COLLECTOR_CMD=
ACCOUNT_3_COLLECTOR_CMD=
ACCOUNT_4_COLLECTOR_CMD=
ACCOUNT_5_COLLECTOR_CMD=
ACCOUNT_6_COLLECTOR_CMD=
ACCOUNT_7_COLLECTOR_CMD=
ACCOUNT_8_COLLECTOR_CMD=
ACCOUNT_1_SOURCE_LABEL=
ACCOUNT_2_SOURCE_LABEL=
ACCOUNT_3_SOURCE_LABEL=
ACCOUNT_4_SOURCE_LABEL=
ACCOUNT_5_SOURCE_LABEL=
ACCOUNT_6_SOURCE_LABEL=
ACCOUNT_7_SOURCE_LABEL=
ACCOUNT_8_SOURCE_LABEL=

# Provider collector toggles (used by collect-account-all.js)
ENABLE_GEMINI_COLLECTOR=false
ENABLE_CLAUDE_COLLECTOR=false
ENABLE_OPENAI_COLLECTOR=false

# OpenAI collector
OPENAI_API_KEY=
OPENAI_USAGE_SOURCE_URL=
OPENAI_USAGE_TOKENS=
OPENAI_DAILY_TOKEN_LIMIT=
OPENAI_MODEL_NAME=OpenAI (Daily Token Budget)
OPENAI_REFRESH_TIME=24 hours, 0 min

# Gemini collector (usage source must return {usageTokens:number} or {usedTokens:number})
GEMINI_USAGE_SOURCE_URL=
GEMINI_SOURCE_AUTH_BEARER=
GEMINI_USAGE_TOKENS=
GEMINI_DAILY_TOKEN_LIMIT=
GEMINI_MODEL_NAME=Gemini (Daily Token Budget)
GEMINI_REFRESH_TIME=24 hours, 0 min

# Claude collector (usage source must return {usageTokens:number} or {usedTokens:number})
CLAUDE_USAGE_SOURCE_URL=
CLAUDE_SOURCE_AUTH_BEARER=
CLAUDE_USAGE_TOKENS=
CLAUDE_DAILY_TOKEN_LIMIT=
CLAUDE_MODEL_NAME=Claude (Daily Token Budget)
CLAUDE_REFRESH_TIME=24 hours, 0 min
